<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>seolhae.neocities.org</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@600;700&family=Baloo+2:wght@700&family=Quicksand:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#3d3a37;
    --ink-soft:#8f8a7d;
    --line:#d8d3c6;
    --sage:#a9c2a0;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:#fdfcf8;
    color:var(--ink);
    font-family:'Quicksand', sans-serif;
    font-size:12px;
    line-height:1.5;
  }
  a{color:#7a8f6f;}
  ::-webkit-scrollbar{width:7px;}
  ::-webkit-scrollbar-track{background:#f2f1ea;}
  ::-webkit-scrollbar-thumb{background:#cfc9bc;}

  .wrap{
    max-width:920px;
    margin:0 auto;
    padding:30px 16px 50px;
    display:grid;
    grid-template-columns:160px 1fr 150px;
    column-gap:26px;
  }

  .photo{
    background:repeating-linear-gradient(135deg,#efece3,#efece3 8px,#e6e2d6 8px,#e6e2d6 16px);
    border:1px solid var(--line);
    color:#b3ad9e;
    display:flex;align-items:center;justify-content:center;
    text-align:center;
    font-size:9.5px;
  }

  /* ---- left column ---- */
  .nav-photo{
    position:relative;
    height:270px;
    overflow-y:auto;
  }
  .nav-photo .doodle{
    position:absolute;inset:0;
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px;
    font-family:'Caveat', cursive;font-weight:700;
  }
  .nav-photo .doodle a{
    color:#fff;text-shadow:0 0 3px rgba(0,0,0,.6);
    font-size:21px;text-decoration:none;line-height:1.1;
  }

  .updates-label{
    text-align:center;font-size:11px;color:var(--ink-soft);margin:10px 0 4px;
  }
  .updates-box{border:1px solid var(--line);background:#fff;}
  .updates{list-style:none;margin:0;padding:6px 8px;max-height:80px;overflow-y:auto;font-size:10.5px;}
  .updates li{padding:2px 0;}

  .small-photo{height:78px;margin-top:10px;}
  .selfie-row{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:10px;}
  .selfie-row .photo{height:70px;font-size:9px;}

  /* ---- center column ---- */
  .center-top{text-align:right;font-size:11px;color:var(--ink-soft);padding-top:2px;}
  .titlewrap{text-align:center;position:relative;margin-top:-6px;}
  h1{
    font-family:'Baloo 2', sans-serif;
    font-weight:700;
    font-size:56px;
    margin:0;
    color:#fdfcf8;
    -webkit-text-stroke:2px var(--ink);
  }
  .sparkle{position:absolute;top:-2px;right:calc(50% - 130px);font-size:18px;color:var(--sage);}

  .center-photo-row{
    display:flex;align-items:center;justify-content:center;gap:14px;
    margin:16px 0 14px;
  }
  .center-photo-row .photo{width:150px;height:150px;}
  .notes{font-size:22px;color:#c9c3b6;line-height:1;}

  .intro-box{
    border:1px solid var(--line);
    background:#fff;
    padding:10px 14px;
    max-height:130px;
    overflow-y:auto;
    font-size:11.5px;
    text-align:center;
    line-height:1.7;
  }
  .intro-box i{color:#9aa88f;}

  .strip{
    text-align:center;
    margin:16px 0 4px;
    font-size:26px;
    letter-spacing:4px;
    color:#d8d2c4;
    user-select:none;
  }
  .foot{text-align:center;font-size:10px;color:var(--ink-soft);margin-top:6px;}

  /* ---- right column ---- */
  .right-photo{height:70px;position:relative;font-size:9px;}
  .bubble{
    position:absolute;top:-8px;right:-6px;
    background:#fff;border:1px solid var(--line);border-radius:14px;
    padding:4px 8px;font-size:8px;color:var(--ink-soft);
    max-width:110px;
  }
  .about-photo{
    height:78px;margin-top:10px;
    font-family:'Caveat',cursive;color:#fff;font-size:16px;font-weight:700;
    text-shadow:0 0 3px rgba(0,0,0,.6);
    background:repeating-linear-gradient(45deg,#565656,#565656 6px,#484848 6px,#484848 12px);
  }
  .current-box{
    border:1px solid var(--line);background:#fff;
    margin-top:10px;padding:8px;text-align:center;
  }
  .current-box .avatar{width:56px;height:56px;margin:0 auto 6px;border:2px dashed var(--line);font-size:8px;}
  .current-box p{margin:1px 0;font-size:9.5px;}
  .current-box .links{margin-top:4px;font-size:8.5px;color:var(--ink-soft);}

  .calendar{border:1px solid var(--line);background:#fff;margin-top:10px;padding:8px;}
  .calendar h5{margin:0 0 6px;text-align:center;font-size:11px;}
  .calendar table{width:100%;border-collapse:collapse;font-size:9px;text-align:center;color:var(--ink-soft);}
  .calendar td.today{background:var(--sage);color:#fff;border-radius:50%;}

  @media (max-width:760px){
    .wrap{grid-template-columns:1fr;}
    .nav-photo{height:200px;}
  }
</style>
</head>
<body>

<div class="wrap">

  <!-- LEFT -->
  <div>
    <div class="photo nav-photo">
      <div class="doodle">
        <a href="#archive">archive</a>
        <a href="#gallery">gallery</a>
        <a href="#shrines">shrines</a>
        <a href="#music">music</a>
        <a href="main.html">sitemap</a>
        <a href="#credits">credits</a>
      </div>
    </div>

    <div class="updates-label">update log ⋆</div>
    <div class="updates-box">
      <ul class="updates">
        <li>7/4: 网站搭建完成</li>
        <li>6/xx: 待补充</li>
        <li>5/xx: 待补充</li>
      </ul>
    </div>

    <div class="photo small-photo">photo</div>

    <div class="selfie-row">
      <div class="photo">selfie</div>
      <div class="photo">pattern</div>
    </div>
  </div>

  <!-- CENTER -->
  <div>
    <div class="center-top">.neocities.org</div>
    <div class="titlewrap">
      <h1>seolhae</h1>
      <span class="sparkle">✼</span>
    </div>

    <div class="center-photo-row">
      <div class="photo">photo</div>
      <div class="notes">♪♫<br>♩</div>
    </div>

    <div class="intro-box">
      hello welcome to <i>seolhae</i> ⋆ this website is a collection of everything i love.
      it's my hobby passion project, here i can share my interests and be myself.
      不定期更新，欢迎常来逛逛～
    </div>

    <div class="strip">╰┈➤ ╰┈➤ ╰┈➤ ╰┈➤</div>
    <div class="foot">seolhae © 2026–forever</div>
  </div>

  <!-- RIGHT -->
  <div>
    <div class="photo right-photo">
      blog
      <div class="bubble">blog is my life . .</div>
    </div>

    <div class="about-photo photo">about</div>

    <div class="current-box">
      <div class="avatar photo">头像</div>
      <p>正在追：待补充番剧</p>
      <div class="links">members list ｜ webring</div>
    </div>

    <div class="calendar" id="calendar">
      <h5 id="cal-title">加载中...</h5>
      <table>
        <thead><tr><td>日</td><td>一</td><td>二</td><td>三</td><td>四</td><td>五</td><td>六</td></tr></thead>
        <tbody id="cal-body"></tbody>
      </table>
    </div>
  </div>

</div>

<script>
  const now = new Date();
  const year = now.getFullYear(), month = now.getMonth();
  const monthNames = ['一月','二月','三月','四月','五月','六月','七月','八月','九月','十月','十一月','十二月'];
  document.getElementById('cal-title').textContent = year + ' 年 ' + monthNames[month];
  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const today = now.getDate();
  let html = '', day = 1;
  for(let row = 0; row < 6 && day <= daysInMonth; row++){
    html += '<tr>';
    for(let col = 0; col < 7; col++){
      if(row === 0 && col < firstDay) html += '<td></td>';
      else if(day > daysInMonth) html += '<td></td>';
      else { html += '<td' + (day === today ? ' class="today"' : '') + '>' + day + '</td>'; day++; }
    }
    html += '</tr>';
  }
  document.getElementById('cal-body').innerHTML = html;
</script>

</body>
</html>
